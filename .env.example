# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── MCP Server ────────────────────────────────────────────────────────────────

# Public base URL of this server (used in OAuth metadata and transport security)
MCP_EXTERNAL_URL=https://mcp.yourdomain.com

# External hostname (optional — derived from MCP_EXTERNAL_URL if not set)
MCP_EXTERNAL_HOST=mcp.yourdomain.com

# Extra allowed hostnames for transport security, comma-separated (optional)
# MCP_ALLOWED_ORIGINS=other.yourdomain.com,staging.yourdomain.com

# Master key fallback for Bearer auth — any user (optional, for emergency access)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=

MCP_HOST=0.0.0.0
MCP_PORT=8765

# OAuth token lifetime in days (default: 30)
TOKEN_TTL_DAYS=30

# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_DB=mcp_sessions
POSTGRES_USER=mcp_user

# Host-side port for pgAdmin / SSH tunnel (internal container port is always 5432)
POSTGRES_HOST_PORT=15432

# Required: strong random password
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Only set manually if connecting to an external PostgreSQL instance:
# DATABASE_URL=postgresql://mcp_user:password@your-host:5432/mcp_sessions

# ── Email Notifications (optional) ───────────────────────────────────────────

# Admin email — receives team request notifications
ADMIN_EMAIL=admin@yourdomain.com

# SMTP config for outgoing email
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
# Set to 'true' for port 465 (SSL), leave empty for STARTTLS
SMTP_SECURE=
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# ── GitHub Integration (optional) ─────────────────────────────────────────────

# Server-level GitHub PAT — fallback when a user has no personal token set.
# Without token: public repos only, 60 req/hour.
# With token: public + private repos, 5000 req/hour.
# Generate at: https://github.com/settings/tokens (scope: repo — read-only)
GITHUB_TOKEN=
