# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── MCP Server ────────────────────────────────────────────────────────────────

# Required: random secret key — authenticate claude.ai web and CLI requests
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=change-me-to-a-random-secret

MCP_HOST=0.0.0.0
MCP_PORT=8765

# External hostname for reverse proxy (Cloudflare Tunnel / nginx)
MCP_EXTERNAL_HOST=mcp.yourdomain.com

# ── Docker ────────────────────────────────────────────────────────────────────

# Directory on VPS containing docker compose project subdirectories
# Structure: /opt/stacks/odoo/docker-compose.yml
COMPOSE_BASE_DIR=/opt/stacks

LOG_MAX_LINES=200
DOCKER_TIMEOUT=60

# GID of docker group on host — check with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=988

# ── PostgreSQL (Session Store) ────────────────────────────────────────────────

# Database credentials — used by both the postgres container and mcp container
POSTGRES_DB=mcp_sessions
POSTGRES_USER=mcp_user

# Required: strong random password
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
POSTGRES_PASSWORD=change-me-to-a-strong-password

# DATABASE_URL is auto-constructed in docker-compose.yml from the vars above.
# Only set this manually if you want to connect to an external PostgreSQL instance:
# DATABASE_URL=postgresql://mcp_user:password@your-host:5432/mcp_sessions
