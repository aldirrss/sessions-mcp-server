# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required: random secret key — used to authenticate claude.ai web requests
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=change-me-to-a-random-secret

# MCP server bind address and port
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Directory on VPS that contains docker compose project subdirectories.
# Structure expected:
#   /opt/stacks/
#     odoo/
#       docker-compose.yml
#     monitoring/
#       docker-compose.yml
COMPOSE_BASE_DIR=/opt/stacks

# Max log lines returned per request (hard cap)
LOG_MAX_LINES=200

# Docker CLI subprocess timeout in seconds
DOCKER_TIMEOUT=60
DOCKER_GID=988